# Copy to `.env` or `.env.local` and fill in values.

# Network (mainnet or sepolia)
NEXT_PUBLIC_STARKNET_NETWORK=mainnet

# Privy (https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# AVNU Paymaster (https://portal.avnu.fi)
# Browser + server: use NEXT_PUBLIC_* so StarkZap can sponsor txs from the client.
NEXT_PUBLIC_AVNU_PAYMASTER_API_KEY=
NEXT_PUBLIC_AVNU_PAYMASTER_URL=https://starknet.paymaster.avnu.fi
# Optional alias (server + inlined to client via next.config when NEXT_PUBLIC_* is unset)
AVNU_API_KEY=

# Monitor / cron (generate a dedicated read-only key for production)
MONITOR_PRIVATE_KEY=

# Vercel Cron auth (optional in development; required in production on Vercel)
CRON_SECRET=

# Database (e.g. Supabase Postgres pooler)
DATABASE_URL=
# Optional: direct URL for Prisma migrations (port 5432)
# DIRECT_URL=

# Telegram Bot (@BotFather)
TELEGRAM_BOT_TOKEN=

# Email (https://resend.com)
RESEND_API_KEY=

# App URL (links in emails / alerts)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Supabase client
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

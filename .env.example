# Supabase Postgres (Project Settings → Database → Connection string)
# Use "URI" for the app. Transaction pooler (port 6543) works well on Vercel.
DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Optional: direct connection (port 5432) for `prisma migrate deploy` from your machine.
# DIRECT_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Supabase client (Project Settings → API) — only if you use @supabase/supabase-js
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# Use the "anon" / "publishable" public key (never the service_role key in NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-or-publishable-key"

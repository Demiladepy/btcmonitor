# ── Starknet ──────────────────────────────────────────────
VITE_STARKNET_NETWORK=sepolia
# Optional: upstream JSON-RPC for /api/starknet-rpc (server-only; avoids browser CORS). Defaults to Cartridge Sepolia.
# STARKNET_SEPOLIA_RPC_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_7

# Dashboard (client): Vesu pairs and balance row symbols — comma-separated; override per network/pool without editing code.
# NEXT_PUBLIC_VESU_POSITION_PAIRS=WBTC/USDC,ETH/USDC
# NEXT_PUBLIC_DASHBOARD_BALANCE_SYMBOLS=ETH,STRK,USDC,WBTC

# ── Privy (server wallets for Starkzap OnboardStrategy.Privy) ──
# Dashboard: https://dashboard.privy.io — App ID + App Secret
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ── Alert API (shared secret between frontend and Vercel functions) ──
# Generate with: openssl rand -hex 32
VITE_ALERT_API_SECRET=change_me_to_a_random_secret
ALERT_API_SECRET=change_me_to_a_random_secret

# ── Telegram Bot ───────────────────────────────────────────
# 1. Message @BotFather on Telegram
# 2. Send /newbot and follow prompts
# 3. Paste the token here
TELEGRAM_BOT_TOKEN=

# ── Resend (email) ─────────────────────────────────────────
# Get API key from https://resend.com
RESEND_API_KEY=

# ── Artemis Analytics (BTC price + Vesu TVL) ──────────────
# Get API key from https://app.artemis.xyz
ARTEMIS_API_KEY=

# ── App URL ────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173

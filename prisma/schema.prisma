generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AlertLevel {
  warning
  danger
  critical
}

model User {
  /// Stable user key. Privy users: Privy wallet ID. Cartridge/external: wallet address.
  id                  String  @id @default(cuid())
  walletAddress       String? @unique
  email               String? @unique
  telegramChatId      String?

  /// Privy wallet ID — stored for auto-protect signing (Privy users only).
  privyWalletId       String?
  /// "privy" | "cartridge" | "external"
  connectionMethod    String  @default("privy")

  monitoringEnabled   Boolean   @default(true)
  mutedUntil          DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  alertPreferences    AlertPreferences?
  monitoredPairs      MonitoredPair[]
  telegramLinks       TelegramLink[]
  alerts              Alert[]
}

model AlertPreferences {
  userId            String @id
  user              User   @relation(fields: [userId], references: [id])

  warningThreshold  Decimal @default(1.50)
  dangerThreshold   Decimal @default(1.20)
  criticalThreshold Decimal @default(1.05)

  /// Alert when position is within this % of liquidation price
  liquidationDistancePct Float @default(15.0)

  emailEnabled      Boolean @default(true)
  telegramEnabled   Boolean @default(false)

  cooldownMinutes   Int @default(15)

  autoProtectEnabled Boolean @default(false)

  notifyContactEmail String?

  notifyPositions    Boolean @default(true)
  notifyYield        Boolean @default(false)
  notifyLiquidation  Boolean @default(true)
  notifyMarket       Boolean @default(false)

  lastMarketDigestAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TelegramLink {
  code      String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  expiresAt DateTime
  chatId    String?
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}

model MonitoredPair {
  id               String @id @default(cuid())
  userId           String
  user             User   @relation(fields: [userId], references: [id])

  collateralSymbol String
  debtSymbol       String

  createdAt DateTime @default(now())

  @@unique([userId, collateralSymbol, debtSymbol])
}

model Alert {
  id               String     @id @default(cuid())
  userId           String
  user             User       @relation(fields: [userId], references: [id])

  collateralSymbol String
  debtSymbol       String

  level            AlertLevel
  healthRatio      Decimal
  message          String

  /// Collateral USD price at which the position would be liquidated
  liquidationPrice Float?
  /// Actual collateral USD price at alert time
  currentPrice     Float?
  /// % drop from currentPrice to liquidationPrice (how close to liquidation)
  distancePct      Float?

  emailSent        Boolean @default(false)
  telegramSent     Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
